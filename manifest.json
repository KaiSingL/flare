{
  "manifest_version": 3,
  "name": "Ask Grok",
  "version": "1.3",
  "description": "Select text on any webpage and quickly ask Grok about it with an optional prompt.",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["https://grok.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "512": "icons/icon512.png"
  }
}