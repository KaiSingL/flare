{
  "manifest_version": 3,
  "name": "Flare: Ask AI & Web Copilot",
  "version": "0.8",
  "description": "Highlight text on any website to instantly ask AI. Summarize, translate, explain, or rewrite content using custom prompts.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["providers.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "512": "icons/icon512.png"
  }
}